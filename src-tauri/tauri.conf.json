{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MT-Manager-Win",
  "version": "0.1.0",
  "identifier": "com.mtmanager.win",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "MT 管理器",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "shortDescription": "MT Manager for Windows",
    "longDescription": "Dual-pane file manager with built-in text/HEX/image editors, in-archive editing and powerful search."
  },
  "plugins": {}
}
